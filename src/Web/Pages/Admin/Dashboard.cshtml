@page
@model InfraStellar.WebRazor.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Painel Administrativo";
}

<div class="alert alert-primary border-0 shadow-sm rounded-3 p-3 mb-4 fw-medium" role="alert">
    ✅ Esta página está protegida com <strong>[Authorize(Roles = "Admin")]</strong>. Apenas administradores têm acesso.
</div>

<div class="mb-4">
    <h1 class="h3 fw-bold text-dark mb-1">Painel Administrativo</h1>
    <p class="text-secondary small mb-0">Visão geral do sistema — área restrita</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-3 p-4 h-100">
            <div class="display-6 mb-2">👥</div>
            <div class="text-secondary fw-bold text-uppercase mb-1" style="font-size: 0.72rem; letter-spacing: 0.05em;">Usuários cadastrados</div>
            <div class="h3 fw-bold text-dark mb-0" id="stat-usuarios">@Model.TotalUsers</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-3 p-4 h-100">
            <div class="display-6 mb-2">🔐</div>
            <div class="text-secondary fw-bold text-uppercase mb-1" style="font-size: 0.72rem; letter-spacing: 0.05em;">Perfis configurados</div>
            <div class="h3 fw-bold text-dark mb-0" id="stat-perfis">@Model.TotalRoles</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-3 p-4 h-100">
            <div class="display-6 mb-2">🌐</div>
            <div class="text-secondary fw-bold text-uppercase mb-1" style="font-size: 0.72rem; letter-spacing: 0.05em;">Ambiente</div>
            <div class="h3 fw-bold text-dark mb-0" id="stat-ambiente">Development</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-3 p-4 h-100">
            <div class="display-6 mb-2">🛡️</div>
            <div class="text-secondary fw-bold text-uppercase mb-1" style="font-size: 0.72rem; letter-spacing: 0.05em;">Autenticação</div>
            <div class="h4 fw-bold text-success mb-0" id="stat-auth">Identity + Cookies</div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 p-4 p-md-5">
    <h2 class="h5 fw-bold text-dark mb-3">Solicitações de Perfis Pendentes</h2>
    
    @if (Model.PendingRequests.Any())
    {
        <div class="table-responsive border rounded-3 bg-white">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="small text-uppercase text-secondary fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Usuário</th>
                        <th class="small text-uppercase text-secondary fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">E-mail</th>
                        <th class="small text-uppercase text-secondary fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Perfil Solicitado</th>
                        <th class="small text-uppercase text-secondary fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Data</th>
                        <th class="small text-uppercase text-secondary fw-bold text-end" style="font-size: 0.75rem; letter-spacing: 0.05em;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model.PendingRequests)
                    {
                        <tr>
                            <td><strong>@request.Usuario?.Nome</strong></td>
                            <td class="text-secondary">@request.Usuario?.Email</td>
                            <td><span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill">@request.RoleNome</span></td>
                            <td>@request.DataSolicitacao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end" style="white-space: nowrap;">
                                <form method="post" style="display: inline-block; margin-right: 0.5rem; margin-bottom: 0;">
                                    <button type="submit" asp-page-handler="ApproveRequest" asp-route-id="@request.Id" class="btn btn-sm btn-success px-3 fw-semibold">Aprovar</button>
                                </form>
                                <form method="post" style="display: inline-block; margin-bottom: 0;">
                                    <button type="submit" asp-page-handler="RejectRequest" asp-route-id="@request.Id" class="btn btn-sm btn-danger px-3 fw-semibold">Rejeitar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-secondary small text-center py-4">Nenhuma solicitação de perfil pendente.</div>
    }
</div>
