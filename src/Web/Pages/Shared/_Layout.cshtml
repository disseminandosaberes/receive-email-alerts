<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — InfraStellar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InfraStellar.WebRazor.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="app-layout">
        <!-- ── Desktop Sidebar (Visible on LG screens) ── -->
        <aside class="app-sidebar d-none d-lg-flex">
            <a class="app-sidebar-logo" asp-page="/Index">
                ⭐ INFRASTELLAR
            </a>
            
            <nav class="app-sidebar-nav">
                <a class="app-sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")" asp-page="/Index">
                    <span>🚀</span> Home
                </a>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="app-sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Alertas") == true ? "active" : "")" asp-page="/Alertas/Index">
                        <span>🔔</span> Meus Alertas
                    </a>
                }
                
                @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                {
                    <a class="app-sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin") == true ? "active" : "")" asp-page="/Admin/Dashboard">
                        <span>🛡️</span> Painel Admin
                    </a>
                }
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="app-sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Account/Profile" ? "active" : "")" asp-page="/Account/Profile">
                        <span>👤</span> Meu Perfil
                    </a>
                }
            </nav>

            <div class="app-sidebar-footer">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var avatarId = User.FindFirst("AvatarId")?.Value;
                    <a asp-page="/Account/Profile" class="d-flex align-items-center gap-2 text-decoration-none" style="color: inherit;" title="Acessar meu perfil">
                        @if (!string.IsNullOrEmpty(avatarId))
                        {
                            <img src="/Account/Profile?handler=Avatar&id=@avatarId" alt="Avatar" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover; border: 1.5px solid var(--color-primary);" />
                        }
                        else
                        {
                            <div style="width: 36px; height: 36px; border-radius: 50%; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; border: 1px dashed var(--border-color);">👤</div>
                        }
                        <div class="d-flex flex-column" style="line-height: 1.2;">
                            <span style="font-size: 0.8125rem; color: var(--text-secondary);">Olá,</span>
                            <strong style="font-size: 0.875rem; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 130px;">@(User.FindFirst("Nome")?.Value ?? User.Identity?.Name)</strong>
                        </div>
                    </a>
                    <form method="post" asp-page="/Account/Logout" class="m-0 w-100 mt-2">
                        <button type="submit" id="nav-logout-btn-desktop" class="stellar-btn stellar-btn-danger w-100" style="padding: 0.45rem 1rem; font-size: 0.8125rem;">
                            <span>🚪</span> Sair
                        </button>
                    </form>
                }
                else
                {
                    <a id="nav-login-btn-desktop" class="stellar-btn stellar-btn-primary w-100" asp-page="/Account/Login">
                        <span>🔑</span> Entrar
                    </a>
                }
            </div>
        </aside>

        <!-- ── Mobile Layout Container ── -->
        <div class="d-flex flex-column w-100 min-vh-100">
            <!-- ── Mobile Top Navbar (Visible on smaller screens) ── -->
            <header class="mobile-topbar d-lg-none">
                <a class="mobile-logo" asp-page="/Index">
                    ⭐ INFRASTELLAR
                </a>
                <button class="mobile-toggle" onclick="toggleMobileSidebar()" aria-label="Menu">
                    ☰
                </button>
            </header>

            <!-- ── Mobile Sidebar Overlay ── -->
            <div class="mobile-sidebar-overlay" id="sidebarOverlay" onclick="toggleMobileSidebar()"></div>

            <!-- ── Mobile Sidebar Offcanvas ── -->
            <div class="mobile-sidebar-offcanvas" id="mobileSidebar">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <a class="mobile-logo" asp-page="/Index" onclick="toggleMobileSidebar()">
                        ⭐ INFRASTELLAR
                    </a>
                    <button class="mobile-toggle" onclick="toggleMobileSidebar()" style="font-size: 1.75rem;">
                        &times;
                    </button>
                </div>
                
                <nav class="app-sidebar-nav">
                    <a class="app-sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")" asp-page="/Index" onclick="toggleMobileSidebar()">
                        <span>🚀</span> Home
                    </a>
                    
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="app-sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Alertas") == true ? "active" : "")" asp-page="/Alertas/Index" onclick="toggleMobileSidebar()">
                            <span>🔔</span> Meus Alertas
                        </a>
                    }
                    
                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                    {
                        <a class="app-sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin") == true ? "active" : "")" asp-page="/Admin/Dashboard" onclick="toggleMobileSidebar()">
                            <span>🛡️</span> Painel Admin
                        </a>
                    }
                    
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="app-sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Account/Profile" ? "active" : "")" asp-page="/Account/Profile" onclick="toggleMobileSidebar()">
                            <span>👤</span> Meu Perfil
                        </a>
                    }
                </nav>

                <div class="app-sidebar-footer mt-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var avatarId = User.FindFirst("AvatarId")?.Value;
                        <a asp-page="/Account/Profile" class="d-flex align-items-center gap-2 text-decoration-none mb-2" style="color: inherit;" onclick="toggleMobileSidebar()">
                            @if (!string.IsNullOrEmpty(avatarId))
                            {
                                <img src="/Account/Profile?handler=Avatar&id=@avatarId" alt="Avatar" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover; border: 1.5px solid var(--color-primary);" />
                            }
                            else
                            {
                                <div style="width: 36px; height: 36px; border-radius: 50%; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; border: 1px dashed var(--border-color);">👤</div>
                            }
                            <div class="d-flex flex-column" style="line-height: 1.2;">
                                <span style="font-size: 0.8125rem; color: var(--text-secondary);">Olá,</span>
                                <strong style="font-size: 0.875rem; color: var(--text-primary);">@(User.FindFirst("Nome")?.Value ?? User.Identity?.Name)</strong>
                            </div>
                        </a>
                        <form method="post" asp-page="/Account/Logout" class="m-0 w-100">
                            <button type="submit" id="nav-logout-btn-mobile" class="stellar-btn stellar-btn-danger w-100" style="padding: 0.45rem 1rem; font-size: 0.8125rem;">
                                <span>🚪</span> Sair
                            </button>
                        </form>
                    }
                    else
                    {
                        <a id="nav-login-btn-mobile" class="stellar-btn stellar-btn-primary w-100" asp-page="/Account/Login" onclick="toggleMobileSidebar()">
                            <span>🔑</span> Entrar
                        </a>
                    }
                </div>
            </div>

            <!-- ── Main Content Area ── -->
            <main class="app-main-content flex-grow-1">
                <div class="container-fluid p-0">
                    @RenderBody()
                </div>
            </main>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleMobileSidebar() {
            var sidebar = document.getElementById('mobileSidebar');
            var overlay = document.getElementById('sidebarOverlay');
            if (sidebar && overlay) {
                sidebar.classList.toggle('show');
                overlay.classList.toggle('show');
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>