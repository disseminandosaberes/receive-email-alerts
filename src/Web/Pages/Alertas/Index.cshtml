@page
@model InfraStellar.WebRazor.Pages.Alertas.IndexModel
@using InfraStellar.Application.DTOs
@{
    ViewData["Title"] = "Meus Alertas";
}

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <h1 class="h3 fw-bold text-dark mb-0">🔔 Meus Alertas</h1>
    <a href="/Alertas/Criar" class="btn btn-primary shadow-sm">＋ Novo Alerta</a>
</div>

@if (!string.IsNullOrEmpty(Model.MensagemSucesso))
{
    <div class="alert alert-success border-0 shadow-sm d-flex align-items-center gap-2 mb-4" role="alert">
        <span>✅</span> <span>@Model.MensagemSucesso</span>
    </div>
}
@if (!string.IsNullOrEmpty(Model.MensagemErro))
{
    <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center gap-2 mb-4" role="alert">
        <span>❌</span> <span>@Model.MensagemErro</span>
    </div>
}

@if (!Model.Alertas.Any())
{
    <div class="card border-0 shadow-sm rounded-3 p-5 text-center">
        <div class="display-4 mb-3 text-secondary">🔕</div>
        <p class="lead text-secondary mb-4">Você ainda não tem alertas criados.</p>
        <a href="/Alertas/Criar" class="btn btn-primary px-4">＋ Criar primeiro alerta</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var alerta in Model.Alertas)
        {
            <div class="col-md-6 col-xxl-4">
                <div class="card h-100 border-0 shadow-sm rounded-3 p-4 d-flex flex-column gap-3">
                    <div class="d-flex align-items-start justify-content-between gap-2">
                        <span class="h5 fw-bold text-dark mb-0 text-truncate" style="max-width: 70%;" title="@alerta.Nome">@alerta.Nome</span>
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill">@alerta.TipoAlertaDominio</span>
                    </div>

                    <a href="@alerta.Url" target="_blank" rel="noopener" class="text-primary text-decoration-none small text-truncate d-block" title="Abrir página monitorada">
                        🌐 @alerta.Url
                    </a>

                    <div class="small text-secondary mb-1">
                        ⏱️ Frequência: <strong>@alerta.IntervaloDescricao</strong>
                    </div>

                    @{
                        bool isNova = alerta.UltimaNovaPublicacao == true;
                        bool temDados = !string.IsNullOrEmpty(alerta.UltimoTitulo);
                    }

                    @if (temDados)
                    {
                        @if (isNova)
                        {
                            <div class="p-3 rounded-3 border border-success-subtle bg-success-subtle text-success-emphasis">
                                <span class="badge bg-success text-white mb-2 uppercase" style="font-size: 0.65rem; letter-spacing: 0.05em;">🆕 Novo Edital!</span>
                                <div class="fw-bold mb-1 small text-break">@alerta.UltimoTitulo</div>
                                <div class="small opacity-75 mb-2">📅 @alerta.UltimaData</div>
                                @if (!string.IsNullOrEmpty(alerta.UltimoLink))
                                {
                                    <a href="@alerta.UltimoLink" target="_blank" rel="noopener" class="text-success text-decoration-none small fw-bold d-inline-flex align-items-center gap-1">
                                        📄 Ver edital
                                    </a>
                                }
                                @if (alerta.UltimaExecucao.HasValue)
                                {
                                    <div class="text-muted small mt-2" style="font-size: 0.7rem;">Verificado em @alerta.UltimaExecucao.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="p-3 rounded-3 border border-light-subtle bg-light text-dark">
                                <div class="fw-semibold mb-1 small text-break">@alerta.UltimoTitulo</div>
                                <div class="text-secondary small mb-2">📅 @alerta.UltimaData</div>
                                @if (!string.IsNullOrEmpty(alerta.UltimoLink))
                                {
                                    <a href="@alerta.UltimoLink" target="_blank" rel="noopener" class="text-primary text-decoration-none small fw-bold d-inline-flex align-items-center gap-1">
                                        📄 Ver edital
                                    </a>
                                }
                                @if (alerta.UltimaExecucao.HasValue)
                                {
                                    <div class="text-muted small mt-2" style="font-size: 0.7rem;">Verificado em @alerta.UltimaExecucao.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-3 rounded-3 border border-light-subtle bg-light text-muted text-center fst-italic small my-auto">
                            Nunca executado — clique em Verificar para checar
                        </div>
                    }

                    <div class="d-flex gap-2 mt-auto pt-3 border-top align-items-center">
                        <form method="post" asp-page-handler="Executar" style="display:contents;">
                            <input type="hidden" name="alertaId" value="@alerta.Id" />
                            <button type="submit" class="btn btn-sm btn-success" id="btn-exec-@alerta.Id">
                                ▶ Verificar
                            </button>
                        </form>

                        <a href="/Alertas/Historico?alertaId=@alerta.Id" class="btn btn-sm btn-outline-secondary">
                            📋 Histórico
                        </a>

                        <form method="post" asp-page-handler="Excluir" style="display:contents;"
                              onsubmit="return confirm('Excluir o alerta \'@alerta.Nome\'?');">
                            <input type="hidden" name="alertaId" value="@alerta.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger ms-auto" id="btn-del-@alerta.Id">🗑</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
