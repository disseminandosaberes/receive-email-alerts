@page
@model IndexModel
@{
    ViewData["Title"] = "Início";
}

<div class="text-center py-5">
    <div class="d-inline-block">
        <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3 py-2 mb-4 fs-6 fw-medium shadow-sm">
            👋 Olá, <strong>@(User.FindFirst("Nome")?.Value ?? User.Identity?.Name)</strong>
        </span>
    </div>
    <h1 class="display-5 fw-bold text-dark mb-3">InfraStellar Platform</h1>
    <p class="lead text-secondary mx-auto" style="max-width: 540px;">
        Gerencie sua infraestrutura de forma inteligente, segura e escalável.
    </p>
</div>

<div class="row g-4 mt-2">
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm rounded-3 p-4">
            <div class="display-6 mb-3">🚀</div>
            <h3 class="h5 fw-bold text-dark mb-2">Deploy Rápido</h3>
            <p class="text-secondary small mb-0">Provisione recursos em segundos com templates pré-configurados e fluxos automatizados.</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm rounded-3 p-4">
            <div class="display-6 mb-3">🔐</div>
            <h3 class="h5 fw-bold text-dark mb-2">Segurança</h3>
            <p class="text-secondary small mb-0">Autenticação robusta baseada em Identity com hash PBKDF2 e controle granular por perfis.</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm rounded-3 p-4">
            <div class="display-6 mb-3">📊</div>
            <h3 class="h5 fw-bold text-dark mb-2">Monitoramento</h3>
            <p class="text-secondary small mb-0">Acompanhe métricas, logs e alertas em tempo real de toda a sua infraestrutura monitorada.</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm rounded-3 p-4">
            <div class="display-6 mb-3">⚙️</div>
            <h3 class="h5 fw-bold text-dark mb-2">Automação</h3>
            <p class="text-secondary small mb-0">Pipelines inteligentes e workflows para operações repetitivas sem esforço manual.</p>
        </div>
    </div>
</div>
