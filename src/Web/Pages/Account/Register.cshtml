@page
@model InfraStellar.WebRazor.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Criar conta";
}

<div class="d-flex align-items-center justify-content-center py-5 w-100" style="min-height: 80vh;">
    <div class="card border-0 shadow-sm rounded-3 p-4 p-md-5 w-100" style="max-width: 440px; background-color: #ffffff;">
        <div class="text-center mb-4">
            <h2 class="h4 fw-bold text-dark mb-1">Criar sua conta</h2>
            <p class="text-secondary small mb-0">Junte-se à plataforma InfraStellar</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <form method="post" id="registerForm">
            <div class="mb-3">
                <label asp-for="Input.Nome" class="form-label fw-bold text-secondary text-uppercase small mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">Nome completo</label>
                <input asp-for="Input.Nome" class="form-control" id="register-nome" placeholder="Seu nome" autocomplete="name" />
                <span asp-validation-for="Input.Nome" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-bold text-secondary text-uppercase small mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">E-mail</label>
                <input asp-for="Input.Email" class="form-control" id="register-email" type="email" placeholder="seu@email.com" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Senha" class="form-label fw-bold text-secondary text-uppercase small mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">Senha</label>
                <input asp-for="Input.Senha" class="form-control" id="register-senha" type="password" placeholder="Mínimo 6 caracteres" autocomplete="new-password" />
                <span asp-validation-for="Input.Senha" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Input.ConfirmarSenha" class="form-label fw-bold text-secondary text-uppercase small mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">Confirmar senha</label>
                <input asp-for="Input.ConfirmarSenha" class="form-control" id="register-confirmar-senha" type="password" placeholder="Repita a senha" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmarSenha" class="text-danger small mt-1 d-block"></span>
            </div>

            <button type="submit" id="register-submit" class="btn btn-primary w-100 py-2 fw-semibold">Criar conta</button>
        </form>

        <div class="text-center mt-4 small text-secondary">
            Já tem uma conta? <a asp-page="/Account/Login" class="text-primary text-decoration-none fw-bold">Entrar</a>
        </div>
    </div>
</div>
