@page
@model InfraStellar.WebRazor.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Cadastro";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Crie sua conta no InfraStellar para acessar todos os recursos da plataforma." />
    <title>@ViewData["Title"] — InfraStellar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 1.25rem;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.4);
        }

        .brand {
            text-align: center;
            margin-bottom: 2rem;
        }

        .brand h1 {
            font-size: 1.75rem;
            font-weight: 700;
            background: linear-gradient(90deg, #a78bfa, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .brand p {
            color: rgba(255,255,255,0.5);
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        label {
            display: block;
            font-size: 0.8125rem;
            font-weight: 500;
            color: rgba(255,255,255,0.7);
            margin-bottom: 0.4rem;
            letter-spacing: 0.03em;
        }

        input {
            width: 100%;
            padding: 0.75rem 1rem;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 0.625rem;
            color: #fff;
            font-size: 0.9375rem;
            font-family: inherit;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        input:focus {
            border-color: #a78bfa;
            box-shadow: 0 0 0 3px rgba(167,139,250,0.2);
        }

        .field-validation-error {
            color: #f87171;
            font-size: 0.75rem;
            margin-top: 0.3rem;
            display: block;
        }

        .validation-summary-errors ul {
            list-style: none;
            background: rgba(248, 113, 113, 0.1);
            border: 1px solid rgba(248, 113, 113, 0.3);
            border-radius: 0.625rem;
            padding: 0.75rem 1rem;
            margin-bottom: 1.25rem;
        }

        .validation-summary-errors li {
            color: #f87171;
            font-size: 0.8125rem;
        }

        .btn-primary {
            width: 100%;
            padding: 0.8125rem;
            background: linear-gradient(135deg, #7c3aed, #4f46e5);
            border: none;
            border-radius: 0.625rem;
            color: #fff;
            font-size: 0.9375rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.1s;
            margin-top: 0.5rem;
        }

        .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
        .btn-primary:active { transform: translateY(0); }

        .footer-link {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.875rem;
            color: rgba(255,255,255,0.5);
        }

        .footer-link a {
            color: #a78bfa;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

        .footer-link a:hover { color: #c4b5fd; }
    </style>
</head>
<body>
    <div class="card">
        <div class="brand">
            <h1>InfraStellar</h1>
            <p>Crie sua conta para começar</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <form method="post" id="registerForm">
            <div class="form-group">
                <label asp-for="Input.Nome">Nome completo</label>
                <input asp-for="Input.Nome" id="register-nome" placeholder="Seu nome" autocomplete="name" />
                <span asp-validation-for="Input.Nome" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Email">E-mail</label>
                <input asp-for="Input.Email" id="register-email" type="email" placeholder="seu@email.com" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Senha">Senha</label>
                <input asp-for="Input.Senha" id="register-senha" type="password" placeholder="Mínimo 6 caracteres" autocomplete="new-password" />
                <span asp-validation-for="Input.Senha" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.ConfirmarSenha">Confirmar senha</label>
                <input asp-for="Input.ConfirmarSenha" id="register-confirmar-senha" type="password" placeholder="Repita a senha" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmarSenha" class="field-validation-error"></span>
            </div>

            <button type="submit" id="register-submit" class="btn-primary">Criar conta</button>
        </form>

        <div class="footer-link">
            Já tem uma conta? <a href="/Account/Login">Entrar</a>
        </div>
    </div>
</body>
</html>
