@page
@model InfraStellar.WebRazor.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="d-flex align-items-center justify-content-center py-5 w-100" style="min-height: 80vh;">
    <div class="card border-0 shadow-sm rounded-3 p-4 p-md-5 w-100" style="max-width: 440px; background-color: #ffffff;">
        <div class="text-center mb-4">
            <h2 class="h4 fw-bold text-dark mb-1">Bem-vindo de volta</h2>
            <p class="text-secondary small mb-0">Acesse sua conta InfraStellar</p>
        </div>

        @if (Model.CadastroRealizadoComSucesso)
        {
            <div class="alert alert-success border-0 shadow-sm rounded-3 p-3 mb-3 small fw-medium" role="alert">
                ✓ Conta criada com sucesso! Faça login para continuar.
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <form method="post" id="loginForm">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-bold text-secondary text-uppercase small mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">E-mail</label>
                <input asp-for="Input.Email" class="form-control" id="login-email" type="email" placeholder="seu@email.com" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Senha" class="form-label fw-bold text-secondary text-uppercase small mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">Senha</label>
                <input asp-for="Input.Senha" class="form-control" id="login-senha" type="password" placeholder="Sua senha" autocomplete="current-password" />
                <span asp-validation-for="Input.Senha" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="Input.LembrarMe" class="form-check-input" type="checkbox" id="login-lembrar" />
                <label asp-for="Input.LembrarMe" class="form-check-label small text-secondary fw-semibold" for="login-lembrar">Lembrar-me neste dispositivo</label>
            </div>

            <button type="submit" id="login-submit" class="btn btn-primary w-100 py-2 fw-semibold">Entrar</button>
        </form>

        <div class="text-center mt-4 small text-secondary">
            Não tem conta? <a asp-page="/Account/Register" class="text-primary text-decoration-none fw-bold">Criar conta</a>
        </div>
    </div>
</div>
