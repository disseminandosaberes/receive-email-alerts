@page
@model InfraStellar.WebRazor.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Entrar";
}

@section Styles {
<style>
    .auth-wrap {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 3rem;
    }

    .auth-card {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 1.25rem;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.4);
    }

    .auth-brand { text-align: center; margin-bottom: 2rem; }

    .auth-brand h2 {
        font-size: 1.5rem;
        font-weight: 700;
        background: linear-gradient(90deg, #a78bfa, #60a5fa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }

    .auth-brand p { color: rgba(255,255,255,0.5); font-size: 0.875rem; margin-top: 0.3rem; }

    .auth-alert-success {
        background: rgba(52,211,153,0.1);
        border: 1px solid rgba(52,211,153,0.3);
        border-radius: 0.625rem;
        padding: 0.75rem 1rem;
        margin-bottom: 1.25rem;
        color: #34d399;
        font-size: 0.8125rem;
    }

    .auth-form-group { margin-bottom: 1.25rem; }

    .auth-card label {
        display: block;
        font-size: 0.8125rem;
        font-weight: 500;
        color: rgba(255,255,255,0.7);
        margin-bottom: 0.4rem;
        letter-spacing: 0.03em;
    }

    .auth-card input[type="email"],
    .auth-card input[type="password"] {
        width: 100%;
        padding: 0.75rem 1rem;
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 0.625rem;
        color: #fff;
        font-size: 0.9375rem;
        font-family: 'Inter', sans-serif;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
    }

    .auth-card input[type="email"]:focus,
    .auth-card input[type="password"]:focus {
        border-color: #a78bfa;
        box-shadow: 0 0 0 3px rgba(167,139,250,0.2);
    }

    .auth-remember {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .auth-remember input[type="checkbox"] {
        width: 1rem; height: 1rem;
        accent-color: #7c3aed; cursor: pointer;
        flex-shrink: 0;
    }

    .auth-remember label { margin: 0; font-size: 0.875rem; cursor: pointer; color: rgba(255,255,255,0.65); }

    .field-validation-error { color: #f87171; font-size: 0.75rem; margin-top: 0.3rem; display: block; }

    .validation-summary-errors ul {
        list-style: none;
        background: rgba(248,113,113,0.1);
        border: 1px solid rgba(248,113,113,0.3);
        border-radius: 0.625rem;
        padding: 0.75rem 1rem;
        margin-bottom: 1.25rem;
    }

    .validation-summary-errors li { color: #f87171; font-size: 0.8125rem; }

    .auth-btn {
        width: 100%;
        padding: 0.8125rem;
        background: linear-gradient(135deg, #7c3aed, #4f46e5);
        border: none;
        border-radius: 0.625rem;
        color: #fff;
        font-size: 0.9375rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.1s;
    }

    .auth-btn:hover { opacity: 0.9; transform: translateY(-1px); }
    .auth-btn:active { transform: translateY(0); }

    .auth-footer-link {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.875rem;
        color: rgba(255,255,255,0.45);
    }

    .auth-footer-link a { color: #a78bfa; text-decoration: none; font-weight: 500; }
    .auth-footer-link a:hover { color: #c4b5fd; }
</style>
}

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-brand">
            <h2>Bem-vindo de volta</h2>
            <p>Acesse sua conta InfraStellar</p>
        </div>

        @if (Model.CadastroRealizadoComSucesso)
        {
            <div class="auth-alert-success">
                ✓ Conta criada com sucesso! Faça login para continuar.
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <form method="post" id="loginForm">
            <div class="auth-form-group">
                <label asp-for="Input.Email">E-mail</label>
                <input asp-for="Input.Email" id="login-email" type="email" placeholder="seu@email.com" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>

            <div class="auth-form-group">
                <label asp-for="Input.Senha">Senha</label>
                <input asp-for="Input.Senha" id="login-senha" type="password" placeholder="Sua senha" autocomplete="current-password" />
                <span asp-validation-for="Input.Senha" class="field-validation-error"></span>
            </div>

            <div class="auth-remember">
                <input asp-for="Input.LembrarMe" id="login-lembrar" type="checkbox" />
                <label asp-for="Input.LembrarMe">Lembrar-me neste dispositivo</label>
            </div>

            <button type="submit" id="login-submit" class="auth-btn">Entrar</button>
        </form>

        <div class="auth-footer-link">
            Não tem conta? <a asp-page="/Account/Register">Criar conta</a>
        </div>
    </div>
</div>
